        <div class="container">
            <p class="text-2xl">
                SQL queries must return results quickly, regardless of the SLA.
            </p>
        </div>
    </section>
    <FullWidth>
        <h4 class="text-4xl">heading 4</h4>
            <p class="text-xl">
        some text 
        </p>
    </FullWidth>
    <section class="mt-8">
        <div class="container">
            <p class="text-2xl">
                text
            </p>
        </div>
    </section>
</DefaultLayout>