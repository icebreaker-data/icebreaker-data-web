---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import FullWidth from '../../components/FullWidth.astro'
---

<DefaultLayout title="Query Isolation">
    <section>
        <div class="container">
            <h1 class="text-center text-6xl md:text-left">
                Query Isolation<hr>
            </h1>
        </div>
    </section>
    <section class="mt-8">
        <div class="container">
            <p class="text-2xl leading-relaxed">
                Query isolation has long been promoted for its data security benefits. <br />It's also foundational to <a href="../demand-shaping">Demand Shaping</a> for Data FinOps execution.
            </p>
        </div>
    </section>
    <FullWidth>
        <h4 class="text-4xl">heading 4</h4>
        <p class="text-xl">
            some text 
        </p>
    </FullWidth>
    <section class="mt-8">
        <div class="container">
            <p class="text-2xl">
                text
            </p>
        </div>
    </section>
</DefaultLayout>