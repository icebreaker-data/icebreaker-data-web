---
import DefaultLayout from '../../layouts/DefaultLayout.astro';
import FullWidth from '../../components/FullWidth.astro';
import Marketecture from '../../components/Marketecture.astro';

import { getCollection, render } from 'astro:content';

import Feature from '../../components/Feature.astro';
import { Link } from 'accessible-astro-components';

const allTechnologies = (await getCollection('technologies')).sort(
    (a, b) => (a.data.order || 0) - (b.data.order || 0),
);

const techWithContent = await Promise.all(
  allTechnologies.map(async (tech) => {
    const { Content } = await render(tech);
    return { tech, Content };
  })
);
console.log('Loaded technologies:',allTechnologies); // will show in the terminal console
---

<DefaultLayout title="Icebreaker Technology Stack">
    <section>
        <div class="container">
            <h1 class="text-center text-6xl md:text-left">
                Advanced Data Stack
            </h1>
        </div>
    </section>

    <section class="mt-8">
        <div class="container">
            <p class="text-2xl">
                Apache Iceberg | Apache DataFusion | Kubernetes
            </p>
        </div>
    </section>

    <FullWidth>
        <p class="text-2xl text-center">Best-in-class open-source technologies, composed into a <strong>serverless query platform</strong> for your data lake and deployed in your VPC.</p>
        <Marketecture />
    </FullWidth>

<section id="features" class="my-24">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
        {techWithContent.map(({ tech, Content }) => (
            /* 4. Pass the frontmatter to the props, and the Markdown to the slot */
            <Feature 
            icon={tech.data.icon} 
            title={tech.data.title}
            >
            <Content />
            </Feature>
        ))}
    </div>
</div>
</section>
    <FullWidth>
        <div class="container mx-auto px-4">
            <h2 class="text-4xl">Deep Dive into Icebreaker</h2>
            <div class="grid grid-cols-1 gap-8 md:grid-cols-3">
                
                {/* FAQ Card */}
                <div class="group flex flex-col gap-4 rounded-xl border-2 border-(--neutral-400) p-8 transition-all hover:border-(--neutral-700) hover:bg-(--neutral-500)/10">
                    <span class="text-sm font-bold uppercase tracking-widest text-(--netural-700)">Resources</span>
                    <h3 class="text-2xl font-semibold text-(--neutral-700)">FAQ</h3>
                    <p class="text-xl">Common questions about deployment, VPC security, and pricing.</p>
                    <div class="mt-auto pt-4 text-2xl">
                        <Link href="/resources/faq">
                            Read FAQ
                        </Link>
                    </div>
                </div>

                {/* Query Isolation Card */}
                <div class="group flex flex-col gap-4 rounded-xl border-2 border-(--neutral-400) p-8 transition-all hover:border-(--primary-300) hover:bg-(--primary-200)/10">
                    <span class="text-sm font-bold uppercase tracking-widest text-(--primary-500)">Architecture</span>
                    <h3 class="text-2xl font-semibold text-(--primary-500)">Query Isolation</h3>
                    <p class="text-xl">How we eliminate noisy neighbor problems and enable query-level unit economics.</p>
                    <div class="mt-auto pt-4 text-2xl">
                        <Link href="/product/query-isolation/">
                            Key Concept
                        </Link>
                    </div>
                </div>

                {/* Demand Shaping Card */}
                <div class="group flex flex-col gap-4 rounded-xl border-2 border-(--neutral-400) p-8 transition-all hover:border-(--secondary-300) hover:bg-(--secondary-100)/10">
                    <span class="text-sm font-bold uppercase tracking-widest text-(--secondary-500)">Performance</span>
                    <h3 class="text-2xl font-semibold text-(--secondary-500)">Demand Shaping</h3>
                    <p class="text-xl">How we optimize resource consumption and smooth out spiky workloads.</p>
                    <div class="mt-auto pt-4 text-2xl">
                        <Link href="/product/demand-shaping/">
                            Key Concept
                        </Link>
                    </div>
                </div>

            </div>
        </div>
    </FullWidth>
</DefaultLayout>