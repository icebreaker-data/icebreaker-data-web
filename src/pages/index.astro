---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import Hero from '../components/Hero.astro';
import ContentMedia from '../components/ContentMedia.astro';
import FullWidth from '../components/FullWidth.astro';
import { getCollection } from 'astro:content'
import { Icon } from 'astro-icon/components'
// Simply fetch all quotes
const quotes = await getCollection('quotes')
console.log('Loaded quotes:', quotes) // This will show in your terminal during build
---

<DefaultLayout title="Icebreaker Data | Serverless Data Platform for Agentic AI"
  description="A private data cloud that lets you run data operations like a business, not a cost center. Built for AI agents, multi-tenant SaaS, and daily enterprise data workloads.">
  <Hero />
  <FullWidth>
    <p class="text-2xl text-center">
      No more idle compute or starved queries. <br>Same BI user experience. Same ETL jobs. Same query performance.
    </p>
    <p class="text-3xl text-center font-semibold">
      Icebreaker lets you run data operations like a business, not a cost center.
    </p>
    <p class="text-2xl text-center">
      Manage your own private data cloud with provider-grade resource controls and unit economics.
    </p>
  </FullWidth>
  <ContentMedia imgSrc="/src/assets/img/savings.png">
    <h2>Control Your Spend</h2>
    <p class="text-xl">
      Agentic AI is fundamantally <a href="/product/demand-shaping/">changing the economics</a> of data analytics. AI agents explore data by trial and error, which consumes resources and costs money. Lots of money.
    </p>
    <p class="text-xl">
      Icebreaker is the only enterprise data platform getting ahead of it. Icebreaker ensures that every query is properly cached, right-sized, throttled, and securely deployed, keeping your budget on pace with innovation.
    </p>
    <div class="flex flex-col gap-3 min-[500px]:flex-row">
      <a class="button has-icon color-secondary" href="/product/demand-shaping/">
        <Icon name="ion:cash-outline" />
          Learn About Demand Shaping
      </a>
    </div>
  </ContentMedia>
  <ContentMedia imgSrc="/src/assets/img/agreement_512.png" reverseImg={true}>
    <h2>Meet Your SLAs</h2>
    <p class="text-xl">
      You deploy bigger warehouses or clusters than necessary. You know it's wasteful, but there are financial penalties when you don't meet your Service Level Agreements.  
    </p>
    <p class="text-xl">
      Icebreaker makes sure every query runs as it should by <strong>intelligently scoping and right-sizing every query</strong>.  
    </p>
    <!-- <p class="text-xl">
      Larger compute instances spin up only when a query requires it. Smaller queries run on spare capacity or smaller instances.
    </p>
    -->
    <div class="flex flex-col gap-3 min-[500px]:flex-row">
      <a class="button has-icon color-secondary" href="/product/demand-shaping/">
        <Icon name="ion:cash-outline" />
          Learn About Demand Shaping
      </a>
    </div>
  </ContentMedia>
  <ContentMedia imgSrc="/src/assets/img/isolation.png">
    <h2>Secure Multi-tenant Data</h2>
    <p class="text-xl">
      SaaS companies struggle to give customers access to their own data without risking "nosey neighbor" leakage. Icebreaker provides <strong>native, query-level isolation</strong>. 
    </p>
    <p class="text-xl">
      It's an elegant and easy way for you to dramatically reduce threat exposure in multi-tenant environments.
    </p>
    </p>
    <div class="flex flex-col gap-3 min-[500px]:flex-row">
      <a class="button has-icon" href="/product/query-isolation/">
        <Icon name="ion:lock-closed-outline" />
          Learn About Query Isolation
      </a>
    </div>
  </ContentMedia>
<!-- <section class=" bg-neutral-100 dark:bg-neutral-600 mt-16 py-12"> -->
  <FullWidth>
    <div class="container grid grid-cols-1 gap-12 md:grid-cols-2">
      <div class="flex flex-col items-start gap-4">
        <h2 class="text-6xl">Great Mentions</h2>
        <p class="text-xl space-content">
          What people are saying about Icebreaker.
        </p>
      </div>
      <div class="container">
        {quotes.length > 0 ? (
          <div class="testimonial-carousel">
            {quotes.map((quote, index) => (
              <div 
                class="testimonial-card" 
                data-index={index}
                style={`
                  border: 1px solid #ccc; 
                  padding: 2rem; 
                  margin: 1rem 0; 
                  border-radius: 0.5rem;
                  display: ${index === 0 ? 'block' : 'none'};
                `}
              >
                <blockquote style="font-style: italic; font-size: 1.2rem;">"{quote.data.quote}"</blockquote>
                <p style="margin-top: 1rem;"><strong>{quote.data.person}</strong></p>
                <p>{quote.data.organization}</p>
                {quote.data.jobTitle && <p>{quote.data.jobTitle}</p>}
              </div>
            ))}
            
            <div class="controls" style="display: flex; justify-content: center; gap: 1rem; margin-top: 2rem;">
              <button id="prev-testimonial" style="padding: 0.5rem 1rem;">&larr; Previous</button>
              <div id="counter" style="display: flex; align-items: center;">
                <span id="current">1</span>/<span id="total">{quotes.length}</span>
              </div>
              <button id="next-testimonial" style="padding: 0.5rem 1rem;">Next &rarr;</button>
            </div>
          </div>
        ) : (
          <p>No testimonials available.</p>
        )}
      </div>
    </div>
  </FullWidth>
  <script>
    // JavaScript to handle the testimonial rotation
    document.addEventListener('DOMContentLoaded', () => {
      const testimonials = document.querySelectorAll('.testimonial-card');
      const prevButton = document.getElementById('prev-testimonial');
      const nextButton = document.getElementById('next-testimonial');
      const currentCounter = document.getElementById('current');
      const totalTestimonials = testimonials.length;
      
      let currentIndex = 0;
      
      function updateTestimonialDisplay() {
        // Hide all testimonials
        testimonials.forEach(card => {
          card.style.display = 'none';
        });
        
        // Show only the current one
        testimonials[currentIndex].style.display = 'block';
        
        // Update counter
        currentCounter.textContent = (currentIndex + 1).toString();
      }
      
      prevButton.addEventListener('click', () => {
        currentIndex = (currentIndex - 1 + totalTestimonials) % totalTestimonials;
        updateTestimonialDisplay();
      });
      
      nextButton.addEventListener('click', () => {
        currentIndex = (currentIndex + 1) % totalTestimonials;
        updateTestimonialDisplay();
      });
      
      // Optional: Auto-rotate testimonials every 7 seconds
      const autoRotate = true;
      const rotationInterval = 7000; // milliseconds
      
      if (autoRotate && totalTestimonials > 1) {
        setInterval(() => {
          currentIndex = (currentIndex + 1) % totalTestimonials;
          updateTestimonialDisplay();
        }, rotationInterval);
      }
    });
  </script>
</DefaultLayout>
