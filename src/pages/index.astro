---
import DefaultLayout from '../layouts/DefaultLayout.astro';
import Hero from '../components/Hero.astro';
import ContentMedia from '../components/ContentMedia.astro';
import FullWidth from '../components/FullWidth.astro';
import { getCollection } from 'astro:content'
import { Icon } from 'astro-icon/components'
// Simply fetch all quotes
const quotes = await getCollection('quotes')
console.log('Loaded quotes:', quotes) // This will show in your terminal during build
---

<DefaultLayout title="Home">
  <Hero />
  <FullWidth>
    <h4 class="text-4xl text-center">The Secret Behind Icebreaker Data</h4>
    <p class="text-xl text-center italic">
      Do you know how the big data cloud companies make a profit? 
    </p>
    <p class="text-3xl text-center">
      <strong>By managing and controlling compute resources.</strong>
    </p>
    <p class="text-xl text-center">
      Icebreaker brings those advanced resource controls to <strong>you</strong>. 
    </p>
  </FullWidth>
  <ContentMedia imgSrc="/src/assets/img/savings.png">
    <h2>Control Your Spend</h2>
    <p class="text-xl">
      Icebreaker fundamantally <strong>changes the economics </strong> of data lakehouse operations. 
    </p>
    <p class="text-xl">
      You advance far beyond separation of storage and compute, auto-scaling, and open software. 
    </p>
    <p class="text-xl">
      Built-in FinOps controls bring financial sanity to unpredictable, on-demand data analytics.
    </p>
    <div class="flex flex-col gap-3 min-[500px]:flex-row">
      <a class="button has-icon color-secondary" href="/product/demand-shaping/">
        <Icon name="ion:calculator-outline" />
          Learn About Demand Shaping
      </a>
    </div>
  </ContentMedia>
  <ContentMedia imgSrc="/src/assets/img/agreement.png" reverseImg={true}>
    <h2>Meet Your SLAs</h2>
    <p class="text-xl">
      Data teams can meet SLAs by running excess compute -- just in-case. You know it's wasteful, but there are penalties when you don't fulfill your Service Level Agreements.  
    </p>
    <p class="text-xl">
      Icebreaker solves this by <strong>intelligently scoping and right-sizing every query</strong>.  
    </p>
    <p class="text-xl">
      Larger (expensive) compute instances will spin up, but only when a query requires it. Smaller queries run on spare capacity or smaller instances.
    </p>
        <div class="flex flex-col gap-3 min-[500px]:flex-row">
      <a class="button has-icon color-secondary" href="/product/demand-shaping/">
        <Icon name="ion:calculator-outline" />
          Learn About Demand Shaping
      </a>
    </div>
  </ContentMedia>
  <ContentMedia imgSrc="/src/assets/img/isolation.png">
    <h2>Secure Your Tenants' Data</h2>
    <p class="text-xl">
      Your SaaS customers want to use <span class="italic">their</span> data, which is stored in <span class="italic">your</span> systems. And yes, you'd love to productize data analytics. 
    </p>
    <p class="text-xl">
      But you learn that it is (a) too risky to share compute resources across customers, and (b) too expensive to isolate tenant workloads by cluster.
    </p>
    <p class="text-xl">
      Icebreaker automatically isolates every query. It's an elegant and simple way to <strong>dramatically reduce threat exposure</strong>. 
    </p>
    <div class="flex flex-col gap-3 min-[500px]:flex-row">
      <a class="button has-icon" href="/product/query-isolation/">
        <Icon name="ion:lock-closed-outline" />
          Learn About Query Isolation
      </a>
    </div>
  </ContentMedia>
<!-- <section class=" bg-neutral-100 dark:bg-neutral-600 mt-16 py-12"> -->
  <FullWidth>
    <div class="container grid grid-cols-1 gap-12 md:grid-cols-2">
      <div class="flex flex-col items-start gap-4">
        <h2 class="text-6xl">Great Mentions</h2>
        <p class="text-xl space-content">
          What people are saying about Icebreaker.
        </p>
      </div>
      <div class="container">
        {quotes.length > 0 ? (
          <div class="testimonial-carousel">
            {quotes.map((quote, index) => (
              <div 
                class="testimonial-card" 
                data-index={index}
                style={`
                  border: 1px solid #ccc; 
                  padding: 2rem; 
                  margin: 1rem 0; 
                  border-radius: 0.5rem;
                  display: ${index === 0 ? 'block' : 'none'};
                `}
              >
                <blockquote style="font-style: italic; font-size: 1.2rem;">"{quote.data.quote}"</blockquote>
                <p style="margin-top: 1rem;"><strong>{quote.data.person}</strong></p>
                <p>{quote.data.organization}</p>
                {quote.data.jobTitle && <p>{quote.data.jobTitle}</p>}
              </div>
            ))}
            
            <div class="controls" style="display: flex; justify-content: center; gap: 1rem; margin-top: 2rem;">
              <button id="prev-testimonial" style="padding: 0.5rem 1rem;">&larr; Previous</button>
              <div id="counter" style="display: flex; align-items: center;">
                <span id="current">1</span>/<span id="total">{quotes.length}</span>
              </div>
              <button id="next-testimonial" style="padding: 0.5rem 1rem;">Next &rarr;</button>
            </div>
          </div>
        ) : (
          <p>No testimonials available.</p>
        )}
      </div>
    </div>
  </FullWidth>
  <script>
    // JavaScript to handle the testimonial rotation
    document.addEventListener('DOMContentLoaded', () => {
      const testimonials = document.querySelectorAll('.testimonial-card');
      const prevButton = document.getElementById('prev-testimonial');
      const nextButton = document.getElementById('next-testimonial');
      const currentCounter = document.getElementById('current');
      const totalTestimonials = testimonials.length;
      
      let currentIndex = 0;
      
      function updateTestimonialDisplay() {
        // Hide all testimonials
        testimonials.forEach(card => {
          card.style.display = 'none';
        });
        
        // Show only the current one
        testimonials[currentIndex].style.display = 'block';
        
        // Update counter
        currentCounter.textContent = (currentIndex + 1).toString();
      }
      
      prevButton.addEventListener('click', () => {
        currentIndex = (currentIndex - 1 + totalTestimonials) % totalTestimonials;
        updateTestimonialDisplay();
      });
      
      nextButton.addEventListener('click', () => {
        currentIndex = (currentIndex + 1) % totalTestimonials;
        updateTestimonialDisplay();
      });
      
      // Optional: Auto-rotate testimonials every 7 seconds
      const autoRotate = true;
      const rotationInterval = 7000; // milliseconds
      
      if (autoRotate && totalTestimonials > 1) {
        setInterval(() => {
          currentIndex = (currentIndex + 1) % totalTestimonials;
          updateTestimonialDisplay();
        }, rotationInterval);
      }
    });
  </script>
</DefaultLayout>
