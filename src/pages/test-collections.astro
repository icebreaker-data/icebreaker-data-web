---
import DefaultLayout from '../layouts/DefaultLayout.astro'
import { getCollection } from 'astro:content'

// Simply fetch all quotes
const quotes = await getCollection('quotes')
console.log('Loaded quotes:', quotes) // This will show in your terminal during build
---

<DefaultLayout title="Testimonials">
  <section class="my-12">
    <div class="container">
      <h1>Customer Testimonials</h1>
      
      {/* First, let's just output the raw data count to confirm loading */}
      <p>Found {quotes.length} testimonials</p>
      
      {/* Then a very basic list to confirm content access */}
      <div class="testimonials-grid">
        {quotes.map((quote) => (
          <div class="testimonial-card" style="border: 1px solid #ccc; padding: 1rem; margin: 1rem 0; border-radius: 0.5rem;">
            <blockquote>"{quote.data.quote}"</blockquote>
            <p><strong>{quote.data.person}</strong></p>
            <p>{quote.data.organization}</p>
            {quote.data.jobTitle && <p>{quote.data.jobTitle}</p>}
          </div>
        ))}
      </div>
    </div>
  </section>
</DefaultLayout>