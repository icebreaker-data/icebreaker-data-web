---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import Fullwidth from '../../components/FullWidth.astro'
import { Card, Pagination } from 'accessible-astro-components'
import { getCollection } from 'astro:content'
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

export const getStaticPaths = (async ({ paginate }) => {
  const people = await getCollection('people',({ data }) => {
  return data.draft !== true;
})
  // Sort people by data.order in ascending order
  const sortedPeople = people.sort((a, b) => {
    // If IDs are numbers, convert to numbers for proper numeric sorting
    const idA = typeof a.data.order === 'number' ? a.data.order : Number(a.data.order) || a.data.order;
    const idB = typeof b.data.order === 'number' ? b.data.order : Number(b.data.order) || b.data.order;
    
    if (typeof idA === 'number' && typeof idB === 'number') {
      return idA - idB; // Numeric sort
    }
    // Fall back to string comparison if not numbers
    return String(idA).localeCompare(String(idB));
  })
  return paginate(sortedPeople, { pageSize: 12 })
}) satisfies GetStaticPaths

interface Props {
  page: Page<CollectionEntry<'people'>>
}

const { page } = Astro.props
---

<DefaultLayout title="About Icebreaker" description="About Icebreaker Data.">
  <section class="my-12">
    <div class="space-content container">
      <h1>About Icebreaker Data</h1>
    </div>
  </section>
  <section class="space-content">
    <Fullwidth>
      <h2>Our Story</h2>

      <p class=class="space-content">
        Icebreaker's founding team members each have decades of professional and academic experience in all things data and AI. 
      </p>
      <p class=class="space-content">
        Icebreaker is the <strong>a-ha!</strong> of seeing how hyperscalers use technology to drive profit, and knowing how adapt that technology to make enterprise data teams more efficient, more lean, and operate like a business. 
      </p>
    </Fullwidth>
  </section>
  <section class="my-12">
    <div class="container">
      <h2 class="space-content">Leadership</h2>
      <!-- <p class="text-sm"><em>People {page.start + 1} through {page.end + 1} of {page.total} total people</em></p>  -->
      <p class=class="space-content">
        Our CEO led multiple engineering teams at AWS, holds 7 patents, and is a co-author of multiple journal publications. 
      </p>
      <ul class="my-3">
        {
          page.data.map((person) => (
            <li>
              <Card
                img={person.data.photo}
                url={'/about/' + person.id}
                title={person.data.name}
                footer={'Role: ' + person.data.jobTitle}
              >
                {person.data.bioBrief}
              </Card>
            </li>
          ))
        }
      </ul>
      <div class="mt-12 grid place-content-center">
        <Pagination
          firstPage={page.url.prev ? '/about' : undefined}
          previousPage={page.url.prev ? page.url.prev : undefined}
          nextPage={page.url.next ? page.url.next : undefined}
          lastPage={page.url.next ? `/about/${Math.ceil(page.total / page.size)}` : undefined}
          currentPage={page.currentPage}
          totalPages={Math.ceil(page.total / page.size)}
        />
      </div>
    </div>
  </section>
</DefaultLayout>

<style lang="scss">
  ul {
    display: grid;
    grid-template-columns: 1fr;
    grid-gap: 4rem;

    @media (min-width: 550px) {
      grid-template-columns: repeat(2, 1fr);
      grid-gap: 2rem;
    }

    @media (min-width: 950px) {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>