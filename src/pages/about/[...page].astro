---
import DefaultLayout from '../../layouts/DefaultLayout.astro'
import { Card, Pagination } from 'accessible-astro-components'
import { getCollection } from 'astro:content'
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'

export const getStaticPaths = (async ({ paginate }) => {
  const people = await getCollection('people')
  // Sort people by data.order in ascending order
  const sortedPeople = people.sort((a, b) => {
    // If IDs are numbers, convert to numbers for proper numeric sorting
    const idA = typeof a.data.order === 'number' ? a.data.order : Number(a.data.order) || a.data.order;
    const idB = typeof b.data.order === 'number' ? b.data.order : Number(b.data.order) || b.data.order;
    
    if (typeof idA === 'number' && typeof idB === 'number') {
      return idA - idB; // Numeric sort
    }
    // Fall back to string comparison if not numbers
    return String(idA).localeCompare(String(idB));
  })
  return paginate(sortedPeople, { pageSize: 6 })
}) satisfies GetStaticPaths

interface Props {
  page: Page<CollectionEntry<'people'>>
}

const { page } = Astro.props
---

<DefaultLayout title="About" description="An example of a portfolio using the Astro Content Collections.">
  <section class="my-12">
    <div class="space-content container">
      <h1>People</h1>
      <p class="text-2xl">
        An example of a portfolio built using Astro Content Collections, showcasing how to organize and display projects dynamically. Check out <a href="https://docs.astro.build/en/guides/content-collections/">Astro Content Collections</a> in the Astro Docs to learn more.
      </p>
    </div>
  </section>
  <section class="my-12">
    <div class="container">
      <p class="text-sm"><em>People {page.start + 1} through {page.end + 1} of {page.total} total people</em></p>
      <ul class="my-3">
        {
          page.data.map((person) => (
            <li>
              <Card
                img={person.data.photo}
                url={'/about/' + person.id}
                title={person.data.name}
                footer={'Role: ' + person.data.jobTitle}
              >
                {person.data.bioBrief}
              </Card>
            </li>
          ))
        }
      </ul>
      <div class="mt-12 grid place-content-center">
        <Pagination
          firstPage={page.url.prev ? '/about' : undefined}
          previousPage={page.url.prev ? page.url.prev : undefined}
          nextPage={page.url.next ? page.url.next : undefined}
          lastPage={page.url.next ? `/about/${Math.ceil(page.total / page.size)}` : undefined}
          currentPage={page.currentPage}
          totalPages={Math.ceil(page.total / page.size)}
        />
      </div>
    </div>
  </section>
</DefaultLayout>

<style lang="scss">
  ul {
    display: grid;
    grid-template-columns: 1fr;
    grid-gap: 4rem;

    @media (min-width: 550px) {
      grid-template-columns: repeat(2, 1fr);
      grid-gap: 2rem;
    }

    @media (min-width: 950px) {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>