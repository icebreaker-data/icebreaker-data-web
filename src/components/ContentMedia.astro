---
import { Media } from 'accessible-astro-components'
import { Image } from 'astro:assets'

interface Props {
  img?: any            // Astro image object
  imgSrc?: string      // fallback string
  alt?: string
  reverseImg?: boolean
}

const { img, imgSrc, alt = '', reverseImg = false }: Props = Astro.props
---

<section class="my-24">
  <div class="container">
    <div class="grid grid-cols-1 gap-24 md:grid-cols-2">

      {!reverseImg ? (
        img ? (
          <Image
            src={img}
            alt={alt}
            class="rounded-lg w-full h-auto"
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        ) : (
          <Media class="rounded-lg" src={imgSrc} />
        )
      ) : ''}

      <div class="space-content flex flex-col justify-center">
        <slot />
      </div>

      {reverseImg ? (
        img ? (
          <Image
            src={img}
            alt={alt}
            class="rounded-lg w-full h-auto"
            sizes="(max-width: 768px) 100vw, 50vw"
          />
        ) : (
          <Media class="rounded-lg" src={imgSrc} />
        )
      ) : ''}

    </div>
  </div>
</section>