---
import { SkipLink } from 'accessible-astro-components'
import Navigation from '../components/Navigation.astro'
import { Modal } from 'accessible-astro-components'
import { Icon } from 'astro-icon/components'
---

<header>
  <SkipLink />
  <Navigation>
    <li class="menu-item contact-cta">
      <a href="/contact/">Contact Us!</a>
    </li>
    <li class="menu-item has-dropdown">
      <button aria-haspopup="true" aria-expanded="false">Product</button>
      <ul class="dropdown-menu">
        <li class="submenu-item"><a href="/product/technology-stack/">The Tech Stack</a></li>
        <li class="submenu-item"><a href="/product/query-isolation/">Query Isolation</a></li>
        <li class="submenu-item"><a href="/product/demand-shaping/">Demand Shaping</a></li>
        <li class="submenu-item"><a href="/product/performance/">Performance</a></li>
      </ul>
    </li>
    <li class="menu-item has-dropdown">
      <button aria-haspopup="true" aria-expanded="false">Resources</button>
      <ul class="dropdown-menu">
        <button id="docs-modal-trigger" class="transition-colors cursor-pointer">
          Docs
        </button>
        <li class="submenu-item"><a href="/resources/faq/">FAQ</a></li>
        <li class="submenu-item"><a href="/resources/usecases/">Use Cases</a></li>
        <li class="submenu-item"><a href="/resources/about/">About Us</a></li>
      </ul>
    </li>    
  </Navigation>
</header>

<Modal
  triggerId="docs-modal-trigger"
  title="Documentation Under Development"
  closeText="Close"
>
  <div class="p-4">
    <p class="text-lg text-(--font-color)">
      We're busy documenting the <br /><strong>Icebreaker Technical Reference</strong>.
    </p>
    <br />
    <p class="text-lg mb-10 text-(--font-color)">
      Contact us for early access!
    </p>
  </div>
  <div class="p-4">
    <a class="button has-icon color-secondary" href="/contact/">
      <Icon name="ion:mail" />
      Tell us how to reach you.
    </a>
</div>
</Modal>

<style lang="scss" is:global>
  @use '../assets/scss/base/outline' as *;

  header {
    // Standardizes the horizontal nav list
    .menu-items {
      display: flex;
      align-items: center; 
      gap: 1.25rem;
    }

    .menu-item {
      display: flex;
      align-items: center;

      button, a {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: transparent;
        border: none;
        font-family: inherit;
        font-weight: 500;
        cursor: pointer;
        padding: 0.5rem 0.75rem;
        transition: color 0.2s ease;
        color: var(--action-color); 
        &:hover {
          color: var(--action-color-state)
        }
      }
    }

    // High-Contrast Contact Button
    .contact-cta a {
      // Background matches the Teal button in your screenshot
      background-color: var(--secondary-color, #5ce1e6);
      color: #0d2137 !important; // Dark navy text for contrast on teal
      border-radius: 4px;
      padding: 8px 18px !important;
      font-weight: 700;
      text-transform: none;
      transition: filter 0.2s ease;

      &:hover {
        filter: brightness(1.1);
        text-decoration: none;
      }
    }

    .type-icon a {
      display: block;
      [data-icon] {
        margin-top: -4px;
        width: 30px;
        height: auto;
        path { fill: var(--action-color); }
      }
      &:hover [data-icon] path {
        fill: var(--action-color-state);
      }
    }
  }
</style>