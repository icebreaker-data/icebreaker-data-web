---
// FeaturePillar.astro
const { index, title, description, listItems = [] } = Astro.props;
---

<div class="flex flex-col rounded-2xl border border-(--neutral-300) p-8 transition-all hover:border-(--secondary-400) hover:shadow-lg dark:border-(--neutral-800) dark:hover:border-(--secondary-400)">
  <div class="mb-6 flex items-baseline gap-4">
    <span class="text-3xl text-(--heading-color) font-bold opacity-85">
      {index}
    </span>
    <h3 class="text-2xl text-(--heading-color)">
      {title}
    </h3>
  </div>
  
  <p class="mb-8 text-lg leading-relaxed text-(--neutral-700) dark:text-(--neutral-400)">
    {description}
  </p>

  {listItems.length > 0 && (
    <ul class="list-checkmark mt-auto space-y-3">
      {listItems.map((item) => (
        <li class="text-base font-medium text-(--neutral-800) dark:text-(--neutral-300)" set:html={item} />
      ))}
    </ul>
  )}
</div>