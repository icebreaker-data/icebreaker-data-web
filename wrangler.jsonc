{
    "name": "icebreaker",
    "main": "./dist/_worker.js/index.js",
    // Update to today's date
    "compatibility_date": "2025-03-25",
    "compatibility_flags": ["nodejs_compat"],
    "assets": {
      "binding": "ASSETS",
      "directory": "./dist"
    },
    "observability": {
      "enabled": true
    },
    "services": [
        {
            "binding": "ICEBREAKER_SLACK_BOT",
            "service": "icebreaker-slack-bot"
        }
    ]
  }